    "react-dom": "~19.2.6",
    "react-i18next": "~17.0.8",
    "react-iframe": "~1.8.5",
    "react-modal": "~3.16.3",
    "react-test-renderer": "~19.2.6",
    "sass": "~1.90.0",
    "typescript": "~5.9.3",
    "vite": "~6.4.2",
    "vitest": "~3.2.3"

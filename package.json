{
  "name": "business-card",
  "version": "3.1.14",
  "description": "Yevhen Fabizhevskyi's personal website.",
  "homepage": "https://fabasoad.github.io/business-card/",
  "scripts": {
    "build:dev": "vite build --mode development",
    "build:prod": "vite build",
    "lint": "biome lint --write src",
    "start:dev": "vite",
    "start:web": "PUBLIC_PATH=../public nodemon --watch ./server server/app.js",
    "test": "vitest run --coverage --reporter=json --outputFile=vitest-report.json",
    "clean": "rm -rf coverage && rm -rf temp",
    "clean:unsafe": "rm -f package-lock.json && rm -rf node_modules"
  },
  "bugs": {
    "url": "https://github.com/fabasoad/business-card/issues",
    "email": "fabasoad@gmail.com"
  },

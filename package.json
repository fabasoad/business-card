    "type": "git",
    "url": "https://github.com/fabasoad/business-card.git"
  },
  "author": {
    "name": "Yevhen Fabizhevskyi",
    "email": "fabasoad@gmail.com",
    "url": "https://github.com/fabasoad"
  },
  "license": "ISC",
  "devDependencies": {
    "@biomejs/biome": "~2.4.15",
    "@popperjs/core": "~2.11.8",
